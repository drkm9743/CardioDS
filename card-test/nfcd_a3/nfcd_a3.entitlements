<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Private NFC access and card emulation -->
	<key>com.apple.private.nfc</key>
	<true/>
	<key>com.apple.nfc.cardemulation</key>
	<true/>

	<!-- IOKit access for NFC user client -->
	<key>com.apple.security.iokit-user-client-class</key>
	<array>
		<string>IONFCUserClient</string>
	</array>

	<!-- Run unsandboxed (sandbox escape via DarkSword exploit sets this up) -->
	<key>com.apple.private.security.no-container</key>
	<true/>

	<!-- Platform binary (allows posix_spawn with persona, needed by launcher) -->
	<key>platform-application</key>
	<true/>
</dict>
</plist>
